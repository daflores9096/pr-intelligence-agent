# Required
OPENAI_API_KEY=""
PINECONE_API_KEY=""

# Pinecone index (create with 1536 dimensions for text-embedding-3-small)
PINECONE_INDEX_NAME="pr-intelligence-docs"

# LangSmith (optional — only works when LANGCHAIN_API_KEY is set)
LANGCHAIN_TRACING_V2="true"
LANGCHAIN_API_KEY=""
LANGCHAIN_PROJECT="pr-intelligence-agent"

# Optional overrides
OPENAI_CHAT_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
